[Script]
三合一网盘挂载 = type=http-request,pattern=^http:\/\/(aliyun|quark|pikpak)\.example\.com,script-path=https://kelee.one/Resource/JavaScript/Fileball/Fileball_mount.js,requires-body=true

[MITM]
hostname = %APPEND% aliyun.example.com, quark.example.com, pikpak.example.com,
