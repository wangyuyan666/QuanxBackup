#!name=TestFlight地区解锁
#!desc=解除TestFlight的区域限制，支持tvOS。\n@可莉🅥
#!category=⚙️ ▸ Kelee Mode
#!URL=https://kelee.one/Tool/Loon/Lpx/TestFlightRegionUnlock.lpx
#!date=2026-06-01 17:11:35

[Rule]
DOMAIN,testflight.apple.com,DIRECT,extended-matching

[Body Rewrite]
http-request ^https?:\/\/testflight\.apple\.com\/v\d\/accounts\/.+?\/install$ "storefrontId"\x20:\x20"\d{6}-\d{2},\d{2}", "storefrontId":"143441-19,29",

[MITM]
hostname = %APPEND% testflight.apple.com
